# Google OAuth Configurations (For Admin Login)
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
ALLOWED_GOOGLE_EMAILS=admin@example.com,allowed1@example.com

# SMTP Configurations (For Email Alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=STARTTLS
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
SMTP_RECEIVER=alerts-receiver@example.com
EMAIL_ENABLED=0
EMAIL_MIN_SEVERITY=CRITICAL
